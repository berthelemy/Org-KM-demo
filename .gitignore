# Obsidian workspace state — personal/local, not shared
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Obsidian cache and sync files
.obsidian/cache
.trash/
.sync-conflict-*

# OS-generated files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# VS Code local settings (dev container config is intentionally kept)
.vscode/settings.json
.vscode/launch.json
.vscode/*.log

# Node / package managers (if any tooling is added later)
node_modules/
npm-debug.log*
yarn-error.log*

# Python (if any scripts are added)
__pycache__/
*.py[cod]
*.pyo
.env
.venv/

# Logs and temp files
*.log
*.tmp
*.bak
*.swp
*~
